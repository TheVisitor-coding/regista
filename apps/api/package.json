    "socket.io": "^4",
    "zod": "^3.24",
    "@regista/shared": "workspace:*",
    "@regista/db": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/cli": "^11",
    "@nestjs/testing": "^11",
    "@swc/cli": "^0.5",
