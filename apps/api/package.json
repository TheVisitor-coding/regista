{
  "name": "@regista/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#services/*": "./app/services/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#providers/*": "./providers/*.js",
    "#config/*": "./config/*.js",
    "#start/*": "./start/*.js",
    "#tests/*": "./tests/*.js"
  },
  "scripts": {
    "dev": "node ace serve --hmr",
    "build": "node ace build",
    "start": "node build/bin/server.js",
    "test": "node ace test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf build"
  },
  "dependencies": {
    "@adonisjs/core": "^6",
    "@adonisjs/cors": "^2",
    "@regista/db": "workspace:*",
    "@regista/shared": "workspace:*",
    "@vinejs/vine": "^3",
    "bcrypt": "^6.0.0",
    "bullmq": "^5",
    "drizzle-orm": "^0.38",
    "ioredis": "5.9.3",
    "jose": "^6.2.0",
    "reflect-metadata": "^0.2",
    "socket.io": "^4"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^7",
    "@adonisjs/tsconfig": "^1",
    "@japa/api-client": "^2",
    "@japa/assert": "^3",
    "@japa/plugin-adonisjs": "^3",
    "@japa/runner": "^3",
    "@swc/core": "^1.10",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22",
    "hot-hook": "^0.4",
    "pino-pretty": "^13",
    "ts-node-maintained": "^10",
    "typescript": "^5.7"
  }
}
