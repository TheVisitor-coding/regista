{
  "name": "regista",
  "private": true,
  "scripts": {
    "dev": "bash scripts/preflight.sh && turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "docker:infra:up": "docker compose up -d postgres redis",
    "docker:infra:down": "docker compose down",
    "docker:infra:logs": "docker compose logs -f postgres redis",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f api web",
    "docker:dev:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --remove-orphans",
    "docker:dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down --remove-orphans",
    "docker:dev:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f api web",
    "db:generate": "turbo db:generate --filter=@regista/db",
    "db:migrate": "turbo db:migrate --filter=@regista/db",
    "db:studio": "turbo db:studio --filter=@regista/db",
    "db:seed": "turbo db:seed --filter=@regista/db",
    "seed": "pnpm --filter @regista/api seed",
    "seed:minimal": "pnpm --filter @regista/api seed:minimal",
    "seed:advance": "pnpm --filter @regista/api seed:advance",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
