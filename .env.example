# ===========================
# Regista - Environment Variables
# ===========================

# Database (PostgreSQL)
DATABASE_URL=postgresql://regista:regista@localhost:5432/regista
POSTGRES_USER=regista
POSTGRES_PASSWORD=regista
POSTGRES_DB=regista

# Redis
REDIS_URL=redis://localhost:6379

# Backend API
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Node
NODE_ENV=development
