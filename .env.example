# ===========================
# Regista - Environment Variables
# ===========================

# Database (PostgreSQL)
DATABASE_URL=postgresql://regista:regista@localhost:5432/regista
POSTGRES_USER=regista
POSTGRES_PASSWORD=regista
POSTGRES_DB=regista

# Redis
REDIS_URL=redis://localhost:6379

# Backend API (AdonisJS)
PORT=3001
HOST=0.0.0.0
APP_KEY=change-me-with-a-long-random-secret
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# Frontend
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Node
NODE_ENV=development
